<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }}</title>
{% if author %}
<meta name="author" content="{{ author }}">
{% endif %}
<link rel="stylesheet" href="{{ reveal_cdn }}/dist/reset.css">
<link rel="stylesheet" href="{{ reveal_cdn }}/dist/reveal.css">
{% if math == 'katex' %}
<link rel="stylesheet" href="{{ katex_cdn }}">
{% endif %}
<style id="lectern-theme">
{{ theme_css }}
</style>
<style id="lectern-layout">
/* reveal bridge: make section.slide the themed, flex-laid-out content box.
   Higher specificity than reveal's own section rules, injected after them, so
   the neutral .slide layout model (anchor grid, padding) survives. */
.reveal .slides { text-align: left; }
.reveal .slides > section.slide,
.reveal .slides > section > section.slide {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100%;
  padding: var(--pad-y, 64px) var(--pad-x, 88px);
  box-sizing: border-box;
}
.reveal .slides section.slide > *:first-child { margin-top: 0; }

/* print-pdf wraps each slide in a `.pdf-page`, which breaks the `>` selectors
   above and lets reveal force `display:block; padding:0` — that jams content
   into the page edge and drops the anchor-grid centering. Re-assert the slide
   layout for the printed master (and anyone using reveal's own Ctrl-P export). */
.print-pdf .slides .pdf-page > section.slide {
  display: flex !important;
  flex-direction: column !important;
  padding: var(--pad-y, 64px) var(--pad-x, 88px) !important;
  box-sizing: border-box !important;
  /* reveal's print `center` mode offsets the section's `top` to center its
     content, which double-counts against our flex anchor grid and shoves a
     `.middle` slide into the lower page. Pin it and let the slide fill the
     page so the flex layout is the single source of vertical placement. */
  position: absolute !important;
  top: 0 !important;
  left: 0 !important;
  height: 100% !important;
  width: 100% !important;
}
</style>
{% if extra_head %}
{{ extra_head }}
{% endif %}
</head>
<body>
<div class="reveal">
<div class="slides">
{% for slide in slides %}
<section {{ slide.attrs }} data-markdown>
<script type="text/template">
{{ slide.markdown }}
</script>
</section>
{% endfor %}
</div>
</div>
<script src="{{ reveal_cdn }}/dist/reveal.js"></script>
<script src="{{ reveal_cdn }}/plugin/markdown/markdown.js"></script>
<script src="{{ reveal_cdn }}/plugin/notes/notes.js"></script>
{% if highlight %}
<script src="{{ reveal_cdn }}/plugin/highlight/highlight.js"></script>
{% endif %}
{% if math %}
<script src="{{ reveal_cdn }}/plugin/math/math.js"></script>
{% endif %}
<script>
  Reveal.initialize(Object.assign({{ init_json }}, {
    plugins: [ {{ plugins | join(', ') }} ]{% if math == 'katex' %},
    katex: {
      delimiters: [
        { left: '$$', right: '$$', display: true },
        { left: '$', right: '$', display: false }
      ]
    }{% endif %}
  }{% if init_extra %}, {{ init_extra }}{% endif %}));
</script>
</body>
</html>
