<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }}</title>
{% if author %}
<meta name="author" content="{{ author }}">
{% endif %}
<link rel="stylesheet" href="{{ reveal_cdn }}/dist/reset.css">
<link rel="stylesheet" href="{{ reveal_cdn }}/dist/reveal.css">
{% if math == 'katex' %}
<link rel="stylesheet" href="{{ katex_cdn }}">
{% endif %}
{% if font_awesome_css %}
<link rel="stylesheet" href="{{ font_awesome_css }}">
{% endif %}
<style id="lectern-deck-baseline">
/* ---- Portable deck vocabulary -------------------------------------------
   A deck authored against a richly-styled theme leans on a handful of classes
   (.kicker/.tag/.seal/.handle/.vert) and a warm second accent (--seal) that not
   every theme defines, so the same deck looked broken under other themes (plain
   text where pills/badges were expected, a two-tone chart collapsing to one
   colour). These low-specificity baselines, injected BEFORE the theme, make a
   deck degrade gracefully under ANY theme: a theme that styles these (its rule
   comes later at equal-or-higher specificity) wins, while bare class selectors
   here still beat reveal's element-level reset (`span { border:0 }`), which a
   cascade @layer could not. `--seal` defaults to a deepened accent — distinct
   from --accent so two-tone art stays legible — unless the theme defines it. */
:root { --seal: color-mix(in srgb, var(--accent) 55%, var(--fg) 45%); }
/* reveal ships Eric-Meyer reset.css, which flattens <sub>/<sup> to
   `font-size:100%; vertical-align:baseline` — so `2<sup>256</sup>` rendered as
   plain inline "256". Restore the normalize.css rendering (this block loads
   after reset.css, so equal-specificity element rules win). */
sub, sup { font-size: 0.75em; line-height: 0; position: relative; vertical-align: baseline; }
sup { top: -0.5em; }
sub { bottom: -0.25em; }
.kicker {
  font-family: var(--font-mono, ui-monospace, monospace);
  text-transform: uppercase; letter-spacing: 0.12em;
  font-size: var(--fs-small, 0.7em); color: var(--muted, currentColor);
}
.tag, .pill {
  display: inline-block; margin: 0.15em 0.25em 0.15em 0;
  /* longhands, not the `border` shorthand: a shorthand whose colour is a var()
     is pending-substitution, and reveal's element reset then wins the box. */
  border-width: 1px; border-style: solid;
  border-color: var(--rule, var(--muted, currentColor));
  padding: 0.34em 0.95em; font-size: var(--fs-small, 0.75em);
  line-height: 1; letter-spacing: 0.04em; color: var(--fg);
}
.pill { border-radius: 999px; }
.tag.warm, .pill.warm { border-color: var(--seal); color: var(--seal); }
.tag.cool, .pill.cool { border-color: var(--accent); color: var(--accent); }
.tag.ink,  .pill.ink  { border-color: var(--fg); color: var(--fg); }
.tag.solid, .pill.solid { color: var(--bg); border-color: transparent; }
.tag.warm.solid, .pill.warm.solid { background: var(--seal); }
.tag.cool.solid, .pill.cool.solid { background: var(--accent); }
.tag.ink.solid,  .pill.ink.solid  { background: var(--fg); }
.seal {
  display: inline-flex; align-items: center; justify-content: center;
  min-width: 2.6em; min-height: 2.6em; padding: 0.3em 0.5em;
  background: var(--seal); color: var(--bg); font-family: var(--font-display, inherit);
}
.seal.hollow {
  background: transparent; color: var(--seal);
  border-width: 2px; border-style: solid; border-color: var(--seal);
}
.seal.round { border-radius: 50%; }
.seal.stack, .vert { writing-mode: vertical-rl; }
.vert { color: var(--muted, currentColor); }
.handle { font-size: var(--fs-small, 0.8em); color: var(--muted, currentColor); }
.handle i { color: var(--seal); margin-right: 0.22em; }
.handle a { color: inherit; }
</style>
<style id="lectern-theme">
{{ theme_css }}
</style>
<style id="lectern-layout">
/* reveal bridge: make section.slide the themed, flex-laid-out content box.
   Higher specificity than reveal's own section rules, injected after them, so
   the neutral .slide layout model (anchor grid, padding) survives. */
.reveal .slides { text-align: left; }
.reveal .slides > section.slide,
.reveal .slides > section > section.slide {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100%;
  padding: var(--pad-y, 64px) var(--pad-x, 88px);
  box-sizing: border-box;
}
.reveal .slides section.slide > *:first-child { margin-top: 0; }

/* The flex layout above is what vertically centers `.middle`/`.bottom` slides.
   reveal would normally override it by setting `display:block` inline on a
   visible slide — and only on the *present* one, so a leaving slide snapped
   from flex-centered to block (top-aligned) mid-fade and flashed. We pass
   `display: "flex"` to Reveal.initialize (see render/reveal.py) so reveal
   applies *flex* inline to every visible slide instead; the layout then holds
   through transitions and hidden slides still get `display:none`. No
   stylesheet `!important` is needed to fight it. */

/* Standardize the quotation source across themes. Themes variously muted,
   accent-coloured, or dimmed `.quotation-source` (and the "— " prefix), which
   washed out — unreadable over photographic backgrounds. Give it the slide's
   own text colour — the same token the quote uses (`--fg`, or `--inverse-fg` on
   dark slides) — so it matches the quote regardless of how a theme wraps it.
   (`inherit` is unreliable: the source can sit in a `<p>` a theme mutes.) It
   stays distinct by its smaller size and the "— " prefix. Scoped to
   `.quotation-source` only, so `.footnote`/`.label` keep their muted treatment. */
.reveal .slides section.slide .quotation-source,
.reveal .slides section.slide .quotation-source::before {
  color: var(--fg) !important;
  opacity: 1 !important;
}
.reveal .slides section.slide.inverse .quotation-source,
.reveal .slides section.slide.inverse .quotation-source::before {
  color: var(--inverse-fg) !important;
}

/* `.on-dark` — force light, legible text on a dark backdrop (a photo or video),
   independent of a theme's `.inverse` treatment. A theme's `.inverse` may be a
   *light* "moment" (cream/paper) whose dark text vanishes on a dark image; this
   is the class to reach for on a dark background-image slide:
   `<!-- slide: .on-dark data-background-image="…" -->`. Fixed near-white (not a
   theme token, since the theme's own fg may be dark) plus a soft shadow for
   legibility over busy imagery. Placed after the quotation rules so it wins. */
.reveal .slides section.slide.on-dark { text-shadow: 0 1px 4px rgba(0, 0, 0, 0.55); }
.reveal .slides section.slide.on-dark,
.reveal .slides section.slide.on-dark h1,
.reveal .slides section.slide.on-dark h2,
.reveal .slides section.slide.on-dark h3,
.reveal .slides section.slide.on-dark p,
.reveal .slides section.slide.on-dark li,
.reveal .slides section.slide.on-dark a,
.reveal .slides section.slide.on-dark .quotation,
.reveal .slides section.slide.on-dark .quotation-source,
.reveal .slides section.slide.on-dark .quotation-source::before {
  color: #f5f5f7 !important;
}
/* Full-opacity text over the backdrop — but NOT on the section itself: reveal
   animates the *section's* opacity for fade transitions, so forcing it to 1 kept
   this slide fully visible while it was an off-screen neighbour (its text bled
   onto adjacent slides). Restrict the override to the text elements. */
.reveal .slides section.slide.on-dark h1,
.reveal .slides section.slide.on-dark h2,
.reveal .slides section.slide.on-dark h3,
.reveal .slides section.slide.on-dark p,
.reveal .slides section.slide.on-dark li,
.reveal .slides section.slide.on-dark a,
.reveal .slides section.slide.on-dark .quotation,
.reveal .slides section.slide.on-dark .quotation-source,
.reveal .slides section.slide.on-dark .quotation-source::before {
  opacity: 1 !important;
}
.reveal .slides section.slide.on-dark a { text-decoration: underline; }

/* When a slide declares a reveal background (image / video / color / gradient),
   reveal paints it on a separate `.slide-background` layer *behind* the section.
   A theme's opaque `.slide` (or `.slide.inverse`) fill would hide it, so make the
   section transparent: the background shows through and the slide's text sits on
   top. `!important` + the high-specificity selector win over any theme's fill.
   Pair a background image with `.inverse` (light text) — or a scrim — for
   legibility; this rule only stops the slide from blocking the image. */
.reveal .slides section.slide[data-background-image],
.reveal .slides section.slide[data-background-video],
.reveal .slides section.slide[data-background-color],
.reveal .slides section.slide[data-background-gradient],
.reveal .slides section.slide[data-background] {
  background: transparent !important;
}

/* reveal copies each slide's classes onto its `.slide-background` layer, so a
   theme's `.slide` padding leaks onto the background and insets the image — a
   border around it. Zero that padding (and pin the content) so a `cover` image
   fills the slide edge to edge. Leave the layer's own background alone so reveal
   can still honour `data-background-color`. NB: match `.slide-background`
   wherever reveal puts it — under `.backgrounds` on screen, but moved into each
   `.pdf-page` in print-pdf — so the PDF master fills too. */
.reveal .slide-background { padding: 0 !important; }
.reveal .slide-background .slide-background-content { inset: 0 !important; }

/* Embedded live visualizations (iframe.embed: D3, WebGL, …) are capped to a
   fraction of the slide height, so they always leave room for the heading/body
   and never overflow the frame — independent of a theme's type scale. The slide
   section has a definite height, so this percentage resolves even though reveal
   forces the visible section to display:block inline (which would defeat a
   flex-shrink approach). The embed's own page resizes its canvas to fit. */
.reveal .slides section.slide iframe.embed {
  max-height: 60%;
  min-height: 0;
  max-width: 100%;
}

/* A standalone graphic on its own line — a Markdown `![alt](src)` image or an
   inlined `<svg>` (via `<!-- include: art.svg -->`), each landing as a single-
   child <p> — fills the space the slide's heading/body leave: generous on a
   graphic-only slide, politely smaller when there's also text, scaled to fit (up
   or down) without distortion or overflow, under any theme.

   The <p> takes the leftover vertical space (flex: 1) and is the positioning
   box; the graphic is taken OUT OF FLOW (absolute, inset: 0). That is load-
   bearing for the PDF: a replaced <img> or an inline <svg> at its intrinsic size
   inflates reveal's *natural-height* measurement of the slide, and reveal then
   paginates the print-pdf master onto a too-tall page — the graphic falls off
   the bottom / spills to an extra page. Out of flow, it never contributes to
   that height; `object-fit: contain` (img) or the SVG's viewBox/preserveAspect-
   Ratio (svg) keeps it contained, and `margin: auto` keeps a *constrained*
   override (a `<!-- .element: style="max-width:…" -->`) centred, not left-pinned.
   A raw `<img style="…">`/`<svg style="…">` is a direct child of the section (not
   a single-child <p>), so it sidesteps this rule and is sized verbatim. */
.reveal .slides section.slide p:has(> img:only-child),
.reveal .slides section.slide p:has(> svg:only-child) {
  display: flex;
  flex: 1 1 auto;          /* take the space heading/caption don't */
  min-height: 0;
  position: relative;      /* positioning box for the out-of-flow graphic */
  width: 100%;             /* don't shrink-wrap the (out-of-flow) child to zero */
  margin: 0;
}
.reveal .slides section.slide p:has(> img:only-child) > img,
.reveal .slides section.slide p:has(> svg:only-child) > svg {
  position: absolute;
  inset: 0;
  margin: auto;            /* centre a constrained override within the box */
  width: 100%;
  height: 100%;
}
.reveal .slides section.slide p:has(> img:only-child) > img {
  object-fit: contain;     /* fill the box, scaling up or down, never distorting */
}

/* `::: {.center}` centers one block within the slide's column without disturbing
   the title/body alignment — handy for an ASCII-art code fence on an otherwise
   left-aligned slide. `align-self` centers the block itself (it shrink-wraps its
   content under the slide's flex layout); a contained `<pre>` keeps left-aligned
   text so its monospace columns stay put. `.place` is positioned absolutely, so
   it's excluded. */
.reveal .slides section.slide > .center:not(.place) {
  align-self: center;
  max-width: 100%;
  text-align: center;
}
.reveal .slides section.slide > .center:not(.place) > pre {
  text-align: left;
}

/* Mermaid diagrams: the source `<pre class="mermaid">` is swapped for a
   `<div class="mermaid">` once rendered (see the script), so `.mermaid` matches
   both. Center the diagram and cap the SVG to a fraction of the slide so a big
   one doesn't bump the frame — the same height-cap story as embeds/images. */
.reveal .slides section.slide pre.mermaid {
  display: flex;
  justify-content: center;
  margin: 0;
  padding: 0;
  background: none;       /* drop the theme's code-block panel behind the diagram */
  min-height: 0;
}
.reveal .slides section.slide pre.mermaid svg {
  max-width: 100%;
  max-height: 62vh;
  height: auto;
}
/* foreignObject clips by default; Mermaid sizes label boxes a hair tight, so the
   last glyph of the longest label can get shaved. Let it spill instead of clip. */
.reveal .slides section.slide pre.mermaid svg foreignObject {
  overflow: visible;
}
/* Mermaid wraps each label in a <p>; the theme's `.slide p` margin would leak in
   and push the text off-center (most visibly in Safari/WebKit). Zero it. */
.reveal .slides section.slide pre.mermaid p {
  margin: 0;
}
/* Mermaid appends a `.mermaidTooltip` helper to <body>; in print it extends a
   few px past the last slide, which Chromium paginates into a trailing BLANK
   page. It's inert on paper — remove it from the printed flow. */
@media print {
  .mermaidTooltip { display: none !important; }
}

/* print-pdf wraps each slide in a `.pdf-page`, which breaks the `>` selectors
   above and lets reveal force `display:block; padding:0` — that jams content
   into the page edge and drops the anchor-grid centering. Re-assert the slide
   layout for the printed master (and anyone using reveal's own Ctrl-P export). */
.print-pdf .slides .pdf-page > section.slide {
  display: flex !important;
  flex-direction: column !important;
  padding: var(--pad-y, 64px) var(--pad-x, 88px) !important;
  box-sizing: border-box !important;
  /* reveal's print `center` mode offsets the section's `top` to center its
     content, which double-counts against our flex anchor grid and shoves a
     `.middle` slide into the lower page. Pin it and let the slide fill the
     page so the flex layout is the single source of vertical placement. */
  position: absolute !important;
  top: 0 !important;
  left: 0 !important;
  height: 100% !important;
  width: 100% !important;
}

/* Visually-hidden but screen-reader-available: the aria-live slide announcer. */
.lectern-sr-only {
  position: absolute; width: 1px; height: 1px; margin: -1px; padding: 0;
  overflow: hidden; clip: rect(0 0 0 0); clip-path: inset(50%);
  white-space: nowrap; border: 0;
}

/* Visible keyboard focus, theme-independent: browser/theme defaults are easy to
   lose on links over a themed background. `:focus-visible` shows it for keyboard
   users only, in the theme accent (which the audit holds to >=3:1 vs --bg). */
.reveal .slides section a:focus-visible,
.reveal .slides section button:focus-visible,
.reveal .slides section iframe:focus-visible,
.reveal .slides section [tabindex]:focus-visible {
  outline: 3px solid var(--accent);
  outline-offset: 3px;
  border-radius: 3px;
}

/* Respect prefers-reduced-motion: zero out reveal's slide / fragment / background
   transitions and any keyframe animation, so the live deck doesn't animate for
   users who ask for less motion. Slides still position and fragments still step —
   they just don't tween. (The PDF master already emulates reduced motion.) */
@media (prefers-reduced-motion: reduce) {
  .reveal .slides section,
  .reveal .slides section *,
  .reveal .backgrounds .slide-background {
    transition-duration: 0s !important;
    transition-delay: 0s !important;
    animation-duration: 0s !important;
    animation-delay: 0s !important;
  }
}

/* Density helpers are layout, not aesthetics, so they belong here and work under
   any theme. `.code-sm` shrinks code so a long ASCII/code block stays on one
   slide; `.dense` tightens vertical rhythm so a list-heavy slide doesn't spill
   off the bottom. High specificity intentionally owns these across all themes. */
.reveal .slides section.slide.code-sm pre { font-size: 13px; line-height: 1.45; }
.reveal .slides section.slide.dense {
  padding-top: calc(var(--pad-y, 64px) * 0.5);
  padding-bottom: calc(var(--pad-y, 64px) * 0.5);
}
.reveal .slides section.slide.dense :is(ul, ol) { line-height: 1.28; }
.reveal .slides section.slide.dense li { margin-top: 0.18em; margin-bottom: 0.18em; }

/* Forced colors (Windows High Contrast): the OS replaces the theme palette with a
   limited system palette, so a cue the theme carried with colour alone needs a
   non-colour fallback. Underline links (don't rely on the accent colour), and pin
   the keyboard-focus ring to the system Highlight so it stays visible. */
@media (forced-colors: active) {
  .reveal .slides section a { text-decoration: underline; }
  .reveal .slides section a:focus-visible,
  .reveal .slides section button:focus-visible,
  .reveal .slides section iframe:focus-visible,
  .reveal .slides section [tabindex]:focus-visible {
    outline-color: Highlight;
  }
}
</style>
{% if extra_head %}
{{ extra_head }}
{% endif %}
</head>
<body>
<div id="lectern-live" class="lectern-sr-only" aria-live="polite" aria-atomic="true"></div>
<div class="reveal">
<div class="slides">
{% for slide in slides %}
<section {{ slide.attrs }} data-markdown>
<script type="text/template">
{{ slide.markdown }}
</script>
</section>
{% endfor %}
</div>
</div>
<script src="{{ reveal_cdn }}/dist/reveal.js"></script>
<script src="{{ reveal_cdn }}/plugin/markdown/markdown.js"></script>
<script src="{{ reveal_cdn }}/plugin/notes/notes.js"></script>
{% if highlight %}
<script src="{{ reveal_cdn }}/plugin/highlight/highlight.js"></script>
{% endif %}
{% if math %}
<script src="{{ reveal_cdn }}/plugin/math/math.js"></script>
{% endif %}
<script>
  Reveal.initialize(Object.assign({{ init_json }}, {
    plugins: [ {{ plugins | join(', ') }} ]{% if math == 'katex' %},
    katex: {
      delimiters: [
        { left: '$$', right: '$$', display: true },
        { left: '$', right: '$', display: false }
      ]
    }{% endif %}
  }{% if init_extra %}, {{ init_extra }}{% endif %}));

  // `::: incremental` marks each item `class="fragment" data-li-frag="N"`, where
  // N is the item's source-order index. reveal's markdown attaches that to the
  // item's last inline element (a <strong>/<em>) when the item is formatted, not
  // the <li> — so only the formatted text would build, not the whole item or its
  // list marker. Worse, a plain item lands the class on the <li> and becomes a
  // fragment at load (index 0) while formatted items are promoted here and get
  // appended after it — so builds fire out of order. Promote the fragment to the
  // <li> wherever the marker landed, pin `data-fragment-index` to N so reveal
  // orders builds by source order, then re-sync.
  Reveal.on('ready', () => {
    let dirty = false;
    document.querySelectorAll('.reveal .slides [data-li-frag]').forEach((el) => {
      const li = el.tagName === 'LI' ? el : el.closest('li');
      const idx = el.getAttribute('data-li-frag');
      if (li && li !== el) {
        li.classList.add('fragment');
        el.classList.remove('fragment');
      }
      const target = li || el;
      if (idx !== null && idx !== '') target.setAttribute('data-fragment-index', idx);
      el.removeAttribute('data-li-frag');
      dirty = true;
    });
    if (dirty) Reveal.sync();
  });

  // Region landmarks: name each slide so screen-reader users can navigate it.
  // A <section> with an accessible name is implicitly an ARIA `region`. Slides
  // with an explicit `label`/`aria-label` keep it; the rest take their heading
  // text (rendered by the markdown plugin, so we wait for `ready`).
  Reveal.on('ready', () => {
    document.querySelectorAll('.reveal .slides section').forEach((s) => {
      if (s.getAttribute('aria-label') || s.getAttribute('aria-labelledby')) return;
      const h = s.querySelector('h1, h2, h3, h4, h5, h6');
      const name = h && h.textContent.trim();
      if (name) s.setAttribute('aria-label', name);
    });
  });

  // Live announcer: speak the current slide on navigation, so screen-reader
  // users hear the change (reveal doesn't announce it). Skipped in print-pdf
  // (no navigation; every slide is laid out at once).
  if (!location.search.includes('print-pdf')) {
    const live = document.getElementById('lectern-live');
    const announce = () => {
      const cur = Reveal.getCurrentSlide();
      if (!live || !cur) return;
      const slides = Reveal.getSlides();
      const pos = slides.indexOf(cur) + 1;
      const h = cur.querySelector('h1, h2, h3, h4, h5, h6');
      const name = cur.getAttribute('aria-label') || (h && h.textContent.trim()) || '';
      live.textContent = `Slide ${pos} of ${slides.length}${name ? ': ' + name : ''}`;
    };
    Reveal.on('ready', announce);
    Reveal.on('slidechanged', announce);
  }
</script>
{% if mermaid %}
<script type="module">
  // Render ```mermaid blocks (lowered to <pre class="mermaid">) client-side,
  // themed from the deck's design tokens. The PDF master waits on
  // window.lecternMermaidReady so diagrams are in the printed vector master.
  window.lecternMermaidReady = false;
  import mermaid from '{{ mermaid_cdn }}';
  const cs = getComputedStyle(document.documentElement);
  const tok = (n, d) => cs.getPropertyValue(n).trim() || d;
  mermaid.initialize({
    startOnLoad: false,
    theme: 'base',
    // SVG <text> labels, not foreignObject HTML: reveal scales each slide with a
    // CSS transform to fit the window, and Safari/WebKit mis-positions
    // foreignObject content under an ancestor transform (the offset grows with
    // the scale). Native SVG text transforms correctly, so labels stay centered
    // at any window size.
    htmlLabels: false,
    flowchart: { htmlLabels: false },
    themeVariables: {
      background: tok('--bg', '#ffffff'),
      primaryColor: tok('--bg', '#ffffff'),
      primaryTextColor: tok('--fg', '#111111'),
      primaryBorderColor: tok('--accent', '#888888'),
      lineColor: tok('--accent', '#888888'),
    },
  });
  // Render in-place on the *visible* slide, not in a detached sandbox: Mermaid
  // mis-measures node boxes (labels overflow/clip) unless it measures in the
  // same DOM context the diagram is shown in. Off-screen reveal slides are
  // display:none, so render each as it becomes current; in print-pdf every slide
  // is laid out at once, so render them all.
  const isPrint = location.search.includes('print-pdf');
  async function render(scope) {
    const nodes = scope.querySelectorAll('pre.mermaid:not([data-processed])');
    if (nodes.length) {
      try { await mermaid.run({ nodes }); } catch (e) { /* leave the source */ }
    }
  }
  async function start() {
    await document.fonts.ready;  // measure with the deck's real fonts
    if (isPrint) {
      await render(document);
    } else {
      Reveal.on('slidechanged', (e) => render(e.currentSlide));
      const cur = document.querySelector('.reveal .slides section.present');
      if (cur) await render(cur);
    }
    window.lecternMermaidReady = true;
  }
  if (window.Reveal && Reveal.isReady && Reveal.isReady()) start();
  else Reveal.on('ready', start);
</script>
{% endif %}
</body>
</html>
