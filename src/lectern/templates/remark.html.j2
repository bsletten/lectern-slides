<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }}</title>
{% if author %}
<meta name="author" content="{{ author }}">
{% endif %}
{% if font_awesome_css %}
<link rel="stylesheet" href="{{ font_awesome_css }}">
{% endif %}
<style id="lectern-theme">
{{ theme_css }}
</style>
<style id="lectern-remark-layout">
/* bridge: map remark's slide container onto the neutral .slide model so the
   .slide-targeted theme (anchor grid, padding, colours) applies. Every slide
   carries the `slide` class via the injected layout template. */
html, body { height: 100%; }
.remark-slide-content { padding: 0; }
.remark-slide-content.slide {
  width: 100%;
  height: 100%;
  padding: var(--pad-y, 64px) var(--pad-x, 88px);
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  font-size: var(--fs-body, 27px);
}
.remark-slide-content.slide > *:first-child { margin-top: 0; }
/* Mermaid: drop the theme's code-block panel behind the diagram and center it. */
.remark-slide-content.slide pre.mermaid {
  display: flex; justify-content: center;
  margin: 0; padding: 0; background: none;
}
.remark-slide-content.slide pre.mermaid svg { max-width: 100%; height: auto; }
.remark-slide-content.slide pre.mermaid svg foreignObject { overflow: visible; }
/* zero the theme's <p> margin that Mermaid's labels would otherwise inherit */
.remark-slide-content.slide pre.mermaid p { margin: 0; }
</style>
</head>
<body>
<script src="{{ remark_cdn }}"></script>
<script>
  var slideshow = remark.create({
    source: {{ source_json }},
    ratio: "{{ ratio }}",
    highlightStyle: "",
    highlightLines: true,
    countIncrementalSlides: false,
    navigation: { scroll: false, touch: true }
  });

  // Any link that leaves the deck opens in a new tab: a click mid-talk otherwise
  // unloads the running deck, losing the current slide and the presenter view.
  // In-page anchors and non-web schemes (`mailto:`, `tel:`) are left alone, as is
  // an explicit target the author set on a raw `<a>`. remark renders the markdown
  // itself, so this runs over its output — once for the slides it has built, and
  // again as each slide is shown (idempotent: an anchor with a target is skipped).
  function externalLinksNewTab() {
    document.querySelectorAll('.remark-slide-content a[href]').forEach(function (a) {
      if (a.hasAttribute('target')) return;
      if ((a.getAttribute('href') || '').startsWith('#')) return;
      if (a.protocol !== 'http:' && a.protocol !== 'https:') return;
      a.setAttribute('target', '_blank');
      // The opened tab must not get a handle on the deck's window.
      var rel = (a.getAttribute('rel') || '').split(/\s+/).filter(Boolean);
      if (rel.indexOf('noopener') === -1) rel.push('noopener');
      a.setAttribute('rel', rel.join(' '));
    });
  }
  slideshow.on('afterShowSlide', externalLinksNewTab);
  externalLinksNewTab();
</script>
{% if mermaid %}
<script type="module">
  // Render ```mermaid blocks (lowered to <pre class="mermaid">), themed from the
  // deck's design tokens. remark.create() has already put every slide in the DOM.
  import mermaid from '{{ mermaid_cdn }}';
  const cs = getComputedStyle(document.documentElement);
  const tok = (n, d) => cs.getPropertyValue(n).trim() || d;
  mermaid.initialize({
    startOnLoad: false,
    theme: 'base',
    // SVG <text> labels (not foreignObject HTML): Safari/WebKit mis-positions
    // foreignObject content under an ancestor CSS transform. See the reveal
    // template for the full rationale.
    htmlLabels: false,
    flowchart: { htmlLabels: false },
    themeVariables: {
      background: tok('--bg', '#ffffff'),
      primaryColor: tok('--bg', '#ffffff'),
      primaryTextColor: tok('--fg', '#111111'),
      primaryBorderColor: tok('--accent', '#888888'),
      lineColor: tok('--accent', '#888888'),
    },
  });
  // Render in-place on the *visible* slide so Mermaid measures node boxes in the
  // same context they're shown in (else labels mis-size/clip). Off-screen remark
  // slides are display:none, so render each one as it's shown.
  await document.fonts.ready;
  async function render() {
    const scope = document.querySelector('.remark-visible') || document;
    const nodes = scope.querySelectorAll('pre.mermaid:not([data-processed])');
    if (nodes.length) {
      try { await mermaid.run({ nodes }); } catch (e) { /* leave the source */ }
    }
  }
  window.slideshow.on('afterShowSlide', render);
  await render();  // the initially-visible slide
</script>
{% endif %}
</body>
</html>
